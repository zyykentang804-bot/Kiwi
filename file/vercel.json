{
  "version": 2,
  "builds": [
    {
      "src": "api/raw.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/list.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/raw", "dest": "/api/raw.js" },
    { "src": "/api/list", "dest": "/api/list.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
